{
  "name": "solamarket-keeper-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Permissionless DLOB keeper bot for solamarket — watches on-chain Order accounts and submits FillOrder transactions when orders cross.",
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "start:compiled": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.4",
    "bs58": "^4.0.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/bs58": "^4.0.4",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
