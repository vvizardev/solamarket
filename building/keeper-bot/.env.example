# ── Required ──────────────────────────────────────────────────────────────────

# Deployed program public key
PROGRAM_ID=7XyK1234...

# Path to the keeper wallet keypair JSON (solana-keygen output)
KEEPER_KEYPAIR=../../wallet/keeper.json

# Comma-separated list of market account public keys to watch
MARKET_PUBKEYS=ABCde123...,XYZfg456...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# HTTP RPC endpoint — use a dedicated provider for production
RPC_ENDPOINT=https://api.devnet.solana.com

# WebSocket endpoint — must match the RPC endpoint provider
WS_ENDPOINT=wss://api.devnet.solana.com

# How often (ms) to re-fetch all orders as a WebSocket fallback
POLL_INTERVAL_MS=2000

# Minimum fill size in collateral units (6-decimal USDC).
# Fills smaller than this are skipped to avoid paying more in SOL tx fees
# than the fill reward earns.  Default: 1000 = 0.001 USDC.
MIN_FILL_SIZE=1000

# ── Example: Helius devnet (recommended) ─────────────────────────────────────
# RPC_ENDPOINT=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# WS_ENDPOINT=wss://devnet.helius-rpc.com/?api-key=YOUR_KEY
