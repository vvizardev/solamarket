# Copy to .env and fill in values

# Solana RPC (default: devnet public endpoint; replace with a dedicated one)
RPC_ENDPOINT=https://api.devnet.solana.com
WS_ENDPOINT=wss://api.devnet.solana.com

# Set after `solana program deploy`
PROGRAM_ID=

# Set after `ts-node scripts/fund-wallet.ts`
COLLATERAL_MINT=

# Keeper config
KEEPER_KEYPAIR=../../wallet/keeper.json
MARKET_PUBKEYS=    # comma-separated list, e.g.: Abc123…,Def456…
POLL_INTERVAL_MS=2000
MIN_FILL_SIZE=1000

# Next.js frontend
NEXT_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com
